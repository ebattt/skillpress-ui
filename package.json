{
  "name": "@ebattt/skillpress-ui",
  "version": "0.4.1",
  "description": "Skillpress UI — design system interno",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ebattt/skillpress-ui.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006",
    "build-storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook build",
    "pack:check": "npm pack --dry-run --cache /tmp/skillpress-npm-cache",
    "check:naming": "node scripts/check-naming.cjs",
    "check:legacy": "node scripts/check-legacy.cjs",
    "check:data-attrs": "node scripts/check-data-attrs.cjs",
    "check:init-contract": "node scripts/check-init-contract.cjs",
    "check:hardcoded-colors": "node scripts/check-hardcoded-colors.cjs",
    "check:css-vars": "node scripts/check-css-vars.cjs",
    "check:breakpoints": "node scripts/check-breakpoints.cjs",
    "build:dist": "node scripts/build-dist-bundles.cjs",
    "build:public-api": "node scripts/build-public-api.cjs",
    "check:contract": "node scripts/check-contract.cjs",
    "check": "npm run check:naming && npm run check:legacy && npm run check:data-attrs && npm run check:init-contract && npm run check:hardcoded-colors && npm run check:css-vars && npm run check:breakpoints && npm run build:dist && npm run pack:check",
    "prepublishOnly": "npm run check && npm run build:public-api && npm run check:contract"
  },
  "files": [
    "fonts/",
    "tokens/",
    "base/",
    "utilities/",
    "primitives/",
    "components/",
    "js/",
    "bundles/",
    "dist/"
  ],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": true,
  "devDependencies": {
    "@storybook/html-vite": "^10.3.5",
    "storybook": "^10.3.5",
    "vite": "^8.0.10"
  }
}
