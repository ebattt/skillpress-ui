{
  "name": "@ebattt/skillpress-ui",
  "version": "0.7.0",
  "description": "Skillpress UI design system",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ebattt/skillpress-ui.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "pack:check": "npm pack --dry-run --cache /tmp/skillpress-npm-cache",
    "prepublishOnly": "npm run check",
    "build:material-symbols": "python scripts/build-material-symbols.py",
    "check:naming": "node scripts/check-naming.cjs",
    "check:legacy": "node scripts/check-legacy.cjs",
    "check:data-attrs": "node scripts/check-data-attrs.cjs",
    "check:init-contract": "node scripts/check-init-contract.cjs",
    "check:hardcoded-colors": "node scripts/check-hardcoded-colors.cjs",
    "check:css-vars": "node scripts/check-css-vars.cjs",
    "check:breakpoints": "node scripts/check-breakpoints.cjs",
    "check:shell-isolation": "node scripts/check-shell-isolation.cjs",
    "build:dist": "node scripts/build-dist-bundles.cjs",
    "build:public-api": "node scripts/build-public-api.cjs",
    "build:cdn": "node scripts/build-public.cjs",
    "build:public": "node scripts/build-public.cjs",
    "verify:cdn": "node scripts/verify-cdn.cjs",
    "check:contract": "node scripts/check-contract.cjs",
    "check": "npm run build:material-symbols && npm run check:naming && npm run check:legacy && npm run check:data-attrs && npm run check:init-contract && npm run check:hardcoded-colors && npm run check:css-vars && npm run check:breakpoints && npm run check:shell-isolation && npm run build:dist && npm run build:public-api && npm run check:contract && npm run pack:check"
  },
  "files": [
    "fonts/",
    "tokens/",
    "base/",
    "utilities/",
    "primitives/",
    "page/",
    "components/",
    "shell/",
    "js/",
    "bundles/",
    "dist/",
    "docs/"
  ],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": true
}
