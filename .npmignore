# .npmignore -- difesa-in-profondita complementare al field `files` in package.json.
# Anche se `files` whitelista esplicitamente cosa pubblicare, .npmignore evita
# che artefatti dev (demo, tooling) finiscano in tarball futuri se
# qualcuno modifica `files`.
.DS_Store
*.log

# Dev tooling
demo-pages/
scripts/
.github/
.claude/

# Build artifacts (eccetto dist/ che pubblichiamo)
*.tgz
node_modules/

# Source-control / editor
.git/
.gitignore
.editorconfig
.vscode/
.idea/

# Test/CI artifacts
coverage/
test-results/
playwright-report/
